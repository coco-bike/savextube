# Telegram 频道搜索配置
# 配置要搜索的频道列表

# 频道 1：无损音乐分享
[[channels]]
name = "无损音乐分享"
username = "@lossless_music"
chat_id = ""  # 留空自动获取
enabled = true
priority = 1  # 优先级，数字越小优先级越高

# 频道 2：华语金曲
[[channels]]
name = "华语金曲"
username = "@chinese_hits"
chat_id = ""
enabled = true
priority = 2

# 频道 3：周杰伦专区
[[channels]]
name = "周杰伦专区"
username = "@jay_chou_fan"
chat_id = ""
enabled = true
priority = 1

