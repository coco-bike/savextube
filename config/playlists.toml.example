# SaveXTube 歌单配置文件
# 配置要下载的歌单列表

# 示例：网易云音乐歌单
[[playlists]]
platform = "netease"
name = "周杰伦经典"
url = "https://music.163.com/#/playlist?id=12345678"
style = "华语流行"
enabled = true
auto_download = false  # 手动触发下载

# 示例：QQ 音乐歌单
[[playlists]]
platform = "qq"
name = "抖音热歌榜"
url = "https://y.qq.com/n/ryqq/playlist/1234567890"
style = "网络热歌"
enabled = true
auto_download = false

# 示例：汽水音乐歌单
[[playlists]]
platform = "qishui"
name = "我喜欢的音乐"
url = "https://qishui.douyin.com/s/i9wXxJGq/"
style = "混合"
enabled = true
auto_download = false

# 添加更多歌单...
